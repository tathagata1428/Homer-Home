/
  Cache-Control: no-store, no-cache, must-revalidate
  CDN-Cache-Control: no-store
  Surrogate-Control: no-store

/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  CDN-Cache-Control: no-store
  Surrogate-Control: no-store

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/icon-192.png
  Cache-Control: public, max-age=31536000, immutable

/icon-512.png
  Cache-Control: public, max-age=31536000, immutable

/icon.svg
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=31536000, immutable

/sounds/*
  Cache-Control: public, max-age=31536000, immutable
