{
  "manifest_version": 3,
  "name": "Homer Home",
  "version": "1.0.0",
  "description": "Personal productivity dashboard with clock, weather, motivational quotes, pomodoro timer, ambient sounds, news feeds, investing charts, and more.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "notifications"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://raw.githubusercontent.com/*",
    "https://official-joke-api.appspot.com/*",
    "https://www.google.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
