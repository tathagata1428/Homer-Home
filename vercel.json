{
  "redirects": [
    {
      "source": "/api",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/api/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(icon-192.png|icon-512.png|icon.svg|manifest.json|sounds/(.*))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
